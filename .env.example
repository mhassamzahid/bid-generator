# ─── Mistral AI ───────────────────────────────────────────────────────────────
# Free API key at: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── PostgreSQL + pgvector ────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
# Free options:
#   Local Docker: docker run -e POSTGRES_PASSWORD=pw -p 5432:5432 pgvector/pgvector:pg16
#   Supabase:     supabase.com (free tier, pgvector pre-installed)
#   Neon:         neon.tech (free tier, enable pgvector in extensions tab)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bid_generator

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ─── RAG / Model Settings ─────────────────────────────────────────────────────
# Number of past bids retrieved for context
RAG_TOP_K=3
# Free Mistral models:
#   mistral-small-latest  — fast, good quality (recommended)
#   open-mistral-7b       — lightest, most rate-limit friendly
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
